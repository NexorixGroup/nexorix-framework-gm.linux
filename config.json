{
    "name": "Nexorix: Novo Mundo",
    "max_players": 100,
    "language": "Portuguese",
    "network": {
        "bind": "0.0.0.0",
        "port": 7777,
        "announce": false,
        "query": true
    },
    "lua": {
        "entry": "lua/gamemode"
    },
    "database": {
        "type": "sqlite",
        "file": "nexorix_data.db",
        "__mysql": "Configuração MySQL (descomente e preencha para usar MySQL)",
        "mysql": {
            "enabled": false,
            "host": "localhost",
            "port": 3306,
            "user": "root",
            "password": "",
            "database": "nexorix"
        }
    },
    "__discord": "Bot Discord — token nunca aparece em logs.",
    "discord": {
        "enabled": false,
        "token": "SEU_TOKEN_AQUI",
        "prefix": "!",
        "channel_id": "SEU_CHANNEL_ID_AQUI"
    },
    "voice": {
        "enabled": true,
        "host": "0.0.0.0",
        "port": 2020,
        "proximity_distance": 50.0,
        "max_streams": 4096,
        "max_effects": 256
    },
    "logging": {
        "enable": true,
        "file": "nexorix_server.log"
    }
}
